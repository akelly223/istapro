@using GestionScolaire.Data
@{
    bool estAdmin = User.IsInRole(AppRoles.Administrateur);
    bool estProf = User.IsInRole(AppRoles.Professeur);
    bool estEtudiant = User.IsInRole(AppRoles.Etudiant);
}
<nav class="nav flex-column mt-3">
    @if (estAdmin)
    {
        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Dashboard">
            <i class="bi bi-speedometer2"></i> Tableau de bord
        </a>
    }
    @if (estProf)
    {
        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="EspaceProfesseur">
            <i class="bi bi-speedometer2"></i> Mon espace
        </a>
    }
    @if (estEtudiant)
    {
        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="MonEspace">
            <i class="bi bi-speedometer2"></i> Mon espace
        </a>
    }

    @if (estAdmin || estProf)
    {
        <a class="nav-link" asp-area="" asp-controller="Students" asp-action="Index">
            <i class="bi bi-people-fill"></i> Étudiants
        </a>
        <a class="nav-link" asp-area="" asp-controller="ClassRooms" asp-action="Index">
            <i class="bi bi-building"></i> Classes
        </a>
        <a class="nav-link" asp-area="" asp-controller="Subjects" asp-action="Index">
            <i class="bi bi-journal-bookmark-fill"></i> Matières
        </a>
        <a class="nav-link" asp-area="" asp-controller="Grades" asp-action="Index">
            <i class="bi bi-clipboard-check-fill"></i> Notes
        </a>
        <a class="nav-link" asp-area="" asp-controller="Homeworks" asp-action="Index">
            <i class="bi bi-journal-text"></i> Devoirs
        </a>
        <a class="nav-link" asp-area="" asp-controller="Attendances" asp-action="Index">
            <i class="bi bi-calendar-check"></i> Présences
        </a>
    }

    @if (estEtudiant)
    {
        <a class="nav-link" asp-area="" asp-controller="Homeworks" asp-action="MesDevoirs">
            <i class="bi bi-journal-text"></i> Mes devoirs
        </a>
    }

    <hr class="text-secondary mx-3" />
    <form asp-controller="Account" asp-action="Logout" method="post">
        <button type="submit" class="nav-link border-0 bg-transparent w-100 text-start">
            <i class="bi bi-box-arrow-right"></i> Se déconnecter
        </button>
    </form>
</nav>
