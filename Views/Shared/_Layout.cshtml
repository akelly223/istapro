<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestion Scolaire</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@{
    // Cette variable nous dit si un utilisateur est connecté ou non (quel que soit son rôle).
    // Elle décide si on affiche la sidebar complète et le menu utilisateur,
    // ou juste un bouton "Se connecter".
    bool estConnecte = User.Identity?.IsAuthenticated ?? false;

    string libelleRole = User.IsInRole(AppRoles.Administrateur) ? "Administrateur"
        : User.IsInRole(AppRoles.Professeur) ? "Professeur"
        : User.IsInRole(AppRoles.Etudiant) ? "Étudiant"
        : "Compte";
}

    <div class="d-flex">

        @if (estConnecte)
        {
            <!-- ================= SIDEBAR (desktop) ================= -->
            <aside class="app-sidebar d-none d-lg-flex flex-column">
                <div class="sidebar-brand">
                    <i class="bi bi-mortarboard-fill"></i>
                    <span>Gestion Scolaire</span>
                </div>
                <partial name="_SidebarNav" />
            </aside>

            <!-- ================= SIDEBAR (mobile - offcanvas) ================= -->
            <div class="offcanvas offcanvas-start app-sidebar text-white" tabindex="-1" id="sidebarMobile">
                <div class="offcanvas-header border-bottom border-secondary-subtle">
                    <span class="sidebar-brand mb-0 p-0 border-0"><i class="bi bi-mortarboard-fill"></i> Gestion Scolaire</span>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Fermer"></button>
                </div>
                <div class="offcanvas-body p-0">
                    <partial name="_SidebarNav" />
                </div>
            </div>
        }

        <!-- ================= CONTENU ================= -->
        <div class="app-content">

            <!-- Navbar du haut -->
            <nav class="app-navbar d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    @if (estConnecte)
                    {
                        <button class="btn btn-outline-secondary d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMobile">
                            <i class="bi bi-list fs-5"></i>
                        </button>
                    }
                    <span class="fw-semibold fs-5 text-dark">@ViewData["Title"]</span>
                </div>

                @if (estConnecte)
                {
                    <div class="dropdown">
                        <button class="btn btn-light d-flex align-items-center gap-2 border" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span class="d-none d-sm-inline">@libelleRole</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item">
                                        <i class="bi bi-box-arrow-right me-2"></i>Se déconnecter
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                        <i class="bi bi-box-arrow-in-right"></i> Se connecter
                    </a>
                }
            </nav>

            <!-- Corps de la page -->
            <main role="main" class="app-main">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
