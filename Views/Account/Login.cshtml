@model LoginViewModel
@{
    ViewData["Title"] = "Connexion";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="card" style="max-width: 420px; width: 100%;">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="icon-badge mx-auto mb-3" style="width:64px;height:64px;font-size:1.8rem;">
                    <i class="bi bi-mortarboard-fill"></i>
                </div>
                <h3 class="fw-bold mb-1">Connexion</h3>
                <p class="text-secondary">Accédez à votre espace de gestion scolaire</p>
            </div>

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="admin@ecole.com" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="bi bi-box-arrow-in-right"></i> Se connecter
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
