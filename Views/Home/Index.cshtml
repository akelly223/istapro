@{
    ViewData["Title"] = "Accueil";
}

<!-- Bannière d'accueil -->
<div class="p-5 mb-4 rounded-3 text-white" style="background: linear-gradient(135deg, #4f46e5, #4338ca);">
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div>
            <h1 class="fw-bold mb-2"><i class="bi bi-mortarboard-fill"></i> Gestion Scolaire</h1>
            <p class="mb-0 fs-5" style="max-width: 600px;">
                Application de gestion des étudiants, des classes, des matières et des notes.
            </p>
        </div>
        <a asp-controller="Account" asp-action="Login" class="btn btn-light btn-lg fw-semibold text-nowrap">
            <i class="bi bi-box-arrow-in-right"></i> Se connecter
        </a>
    </div>
</div>

<!-- Cartes de présentation des modules -->
<div class="row g-4">
    <div class="col-md-6 col-lg-3">
        <div class="card card-stat h-100">
            <div class="card-body">
                <div class="icon-badge mb-3"><i class="bi bi-people-fill"></i></div>
                <h5 class="card-title">Étudiants</h5>
                <p class="card-text text-secondary">Ajouter, modifier et suivre le dossier de chaque étudiant.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card card-stat h-100">
            <div class="card-body">
                <div class="icon-badge mb-3"><i class="bi bi-building"></i></div>
                <h5 class="card-title">Classes</h5>
                <p class="card-text text-secondary">Organiser les étudiants par classe et par niveau.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card card-stat h-100">
            <div class="card-body">
                <div class="icon-badge mb-3"><i class="bi bi-journal-bookmark-fill"></i></div>
                <h5 class="card-title">Matières</h5>
                <p class="card-text text-secondary">Définir les matières enseignées et leur coefficient.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card card-stat h-100">
            <div class="card-body">
                <div class="icon-badge mb-3"><i class="bi bi-clipboard-check-fill"></i></div>
                <h5 class="card-title">Notes</h5>
                <p class="card-text text-secondary">Attribuer les notes et consulter les résultats.</p>
            </div>
        </div>
    </div>
</div>

<p class="text-secondary mt-4">
    <i class="bi bi-check-circle"></i>
    Tous les modules sont opérationnels : connectez-vous pour accéder au tableau de bord.
</p>
