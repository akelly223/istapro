@model Student
@{
    ViewData["Title"] = "Mon espace";
    var notes = ViewBag.Notes as List<Grade> ?? new List<Grade>();
    double? moyenne = ViewBag.Moyenne as double?;
}

<div class="mb-4">
    <h2 class="fw-bold mb-1">Bonjour @Model.Prenom</h2>
    <p class="text-secondary mb-0">Voici ton espace personnel.</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-person-badge text-primary"></i> Mon profil</h5>
                <dl class="row mb-0 mt-3">
                    <dt class="col-5 text-secondary">Nom</dt>
                    <dd class="col-7">@Model.Nom</dd>

                    <dt class="col-5 text-secondary">Prénom</dt>
                    <dd class="col-7">@Model.Prenom</dd>

                    <dt class="col-5 text-secondary">Email</dt>
                    <dd class="col-7">@Model.Email</dd>

                    <dt class="col-5 text-secondary">Date de naissance</dt>
                    <dd class="col-7">@Model.DateNaissance.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-5 text-secondary">Classe</dt>
                    <dd class="col-7">@Model.ClassRoom?.Nom (@Model.ClassRoom?.Niveau)</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title"><i class="bi bi-graph-up text-primary"></i> Ma moyenne</h5>
                @if (moyenne.HasValue)
                {
                    <div class="display-5 fw-bold @(moyenne >= 10 ? "text-success" : "text-danger") mt-2">
                        @moyenne.Value.ToString("0.00") <span class="fs-5 text-secondary">/ 20</span>
                    </div>
                }
                else
                {
                    <p class="text-secondary mt-2">Aucune note enregistrée pour le moment.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title"><i class="bi bi-journal-text text-primary"></i> Mes devoirs</h5>
                <p class="text-secondary">
                    @ViewBag.NombreDevoirsRendus rendu(s) envoyé(s) sur @ViewBag.NombreDevoirsClasse devoir(s) assigné(s) à ma classe.
                </p>
                <a asp-controller="Homeworks" asp-action="MesDevoirs" class="btn btn-primary mt-auto">
                    <i class="bi bi-arrow-right"></i> Voir mes devoirs
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <h5 class="card-title p-3 pb-0 mb-0"><i class="bi bi-clipboard-check-fill text-primary"></i> Mes notes</h5>
        <div class="table-responsive">
            <table class="table table-modern align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">Matière</th>
                        <th>Note</th>
                        <th>Date d'évaluation</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!notes.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-secondary py-4">Aucune note pour le moment.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var note in notes)
                        {
                            <tr>
                                <td class="ps-3 fw-semibold">@note.Subject?.Nom</td>
                                <td>
                                    <span class="badge rounded-pill @(note.Valeur >= 10 ? "text-bg-success" : "text-bg-danger")">
                                        @note.Valeur.ToString("0.##") / 20
                                    </span>
                                </td>
                                <td>@note.DateEvaluation.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
