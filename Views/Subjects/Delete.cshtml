@model Subject
@{
    ViewData["Title"] = "Supprimer une matière";
    int nombreNotes = (int)(ViewBag.NombreNotes ?? 0);
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="fw-bold mb-0">Supprimer une matière</h2>
</div>

<div class="card" style="max-width: 560px;">
    <div class="card-body p-4">
        <div class="alert alert-danger d-flex align-items-start gap-2">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <div>
                Cette action est définitive.
                @if (nombreNotes > 0)
                {
                    <span><strong>@nombreNotes note(s) enregistrée(s)</strong> pour cette matière seront elles aussi supprimées.</span>
                }
                else
                {
                    <span>Confirmez-vous la suppression de cette matière ?</span>
                }
            </div>
        </div>

        <dl class="row mb-4">
            <dt class="col-sm-4 text-secondary">Nom</dt>
            <dd class="col-sm-8">@Model.Nom</dd>

            <dt class="col-sm-4 text-secondary">Coefficient</dt>
            <dd class="col-sm-8">@Model.Coefficient</dd>

            <dt class="col-sm-4 text-secondary">Notes concernées</dt>
            <dd class="col-sm-8">@nombreNotes</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash3"></i> Confirmer la suppression
                </button>
                <a asp-action="Index" class="btn btn-light border">Annuler</a>
            </div>
        </form>
    </div>
</div>
