@model Subject
@{
    ViewData["Title"] = "Ajouter une matière";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="fw-bold mb-0">Ajouter une matière</h2>
</div>

<div class="card" style="max-width: 560px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="mb-3"></div>

            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Nom" class="form-label"></label>
                    <input asp-for="Nom" class="form-control" placeholder="Mathématiques" />
                    <span asp-validation-for="Nom" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Coefficient" class="form-label"></label>
                    <input asp-for="Coefficient" class="form-control" placeholder="3" />
                    <span asp-validation-for="Coefficient" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Enregistrer
                </button>
                <a asp-action="Index" class="btn btn-light border">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
