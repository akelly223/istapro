@model Grade
@{
    ViewData["Title"] = "Supprimer une note";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="fw-bold mb-0">Supprimer une note</h2>
</div>

<div class="card" style="max-width: 560px;">
    <div class="card-body p-4">
        <div class="alert alert-danger d-flex align-items-start gap-2">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <div>Cette action est définitive. Confirmez-vous la suppression de cette note ?</div>
        </div>

        <dl class="row mb-4">
            <dt class="col-sm-4 text-secondary">Étudiant</dt>
            <dd class="col-sm-8">@Model.Student?.Nom @Model.Student?.Prenom</dd>

            <dt class="col-sm-4 text-secondary">Matière</dt>
            <dd class="col-sm-8">@Model.Subject?.Nom</dd>

            <dt class="col-sm-4 text-secondary">Note</dt>
            <dd class="col-sm-8">@Model.Valeur.ToString("0.##") / 20</dd>

            <dt class="col-sm-4 text-secondary">Date d'évaluation</dt>
            <dd class="col-sm-8">@Model.DateEvaluation.ToString("dd/MM/yyyy")</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash3"></i> Confirmer la suppression
                </button>
                <a asp-action="Index" class="btn btn-light border">Annuler</a>
            </div>
        </form>
    </div>
</div>
