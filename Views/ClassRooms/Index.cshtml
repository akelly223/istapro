@model IEnumerable<ClassRoom>
@{
    ViewData["Title"] = "Classes";
    bool estAdmin = User.IsInRole(AppRoles.Administrateur);
}

<div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 mb-4">
    <div>
        <h2 class="fw-bold mb-1">Classes</h2>
        <p class="text-secondary mb-0">Liste des classes de l'établissement.</p>
    </div>
    @if (estAdmin)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-building-add"></i> Ajouter une classe
        </a>
    }
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-modern align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">Nom</th>
                        <th>Niveau</th>
                        <th>Étudiants</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-secondary py-4">
                                Aucune classe enregistrée pour le moment.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var classe in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-semibold">@classe.Nom</td>
                                <td>@classe.Niveau</td>
                                <td>
                                    <span class="badge rounded-pill text-bg-light border">
                                        <i class="bi bi-people-fill"></i> @(classe.Students?.Count ?? 0)
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    @if (estAdmin)
                                    {
                                        <a asp-action="Edit" asp-route-id="@classe.Id" class="btn btn-sm btn-outline-secondary" title="Modifier">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@classe.Id" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-secondary small">Lecture seule</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
