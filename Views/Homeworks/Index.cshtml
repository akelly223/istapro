@model IEnumerable<Homework>
@{
    ViewData["Title"] = "Devoirs";
}

<div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 mb-4">
    <div>
        <h2 class="fw-bold mb-1">Devoirs</h2>
        <p class="text-secondary mb-0">Devoirs assignés aux classes.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Assigner un devoir
    </a>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i> @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-modern align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">Titre</th>
                        <th>Matière</th>
                        <th>Classe</th>
                        <th>Date limite</th>
                        <th>Rendus</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-secondary py-4">
                                Aucun devoir assigné pour le moment.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var devoir in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-semibold">@devoir.Titre</td>
                                <td>@devoir.Subject?.Nom</td>
                                <td>@devoir.ClassRoom?.Nom</td>
                                <td>@devoir.DateLimite.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a asp-action="Rendus" asp-route-id="@devoir.Id" class="badge rounded-pill text-bg-light border text-decoration-none">
                                        <i class="bi bi-inbox"></i> @(devoir.Soumissions?.Count ?? 0)
                                    </a>
                                </td>
                                <td class="text-end pe-3">
                                    <a asp-action="Edit" asp-route-id="@devoir.Id" class="btn btn-sm btn-outline-secondary" title="Modifier">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@devoir.Id" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
