@model Homework
@{
    ViewData["Title"] = "Supprimer un devoir";
    int nombreRendus = Model.Soumissions?.Count ?? 0;
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="fw-bold mb-0">Supprimer un devoir</h2>
</div>

<div class="card" style="max-width: 560px;">
    <div class="card-body p-4">
        <div class="alert alert-danger d-flex align-items-start gap-2">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <div>
                Cette action est définitive.
                @if (nombreRendus > 0)
                {
                    <span><strong>@nombreRendus rendu(s)</strong> envoyé(s) par des étudiants pour ce devoir seront eux aussi supprimés (fichiers inclus).</span>
                }
                else
                {
                    <span>Confirmez-vous la suppression de ce devoir ?</span>
                }
            </div>
        </div>

        <dl class="row mb-4">
            <dt class="col-sm-4 text-secondary">Titre</dt>
            <dd class="col-sm-8">@Model.Titre</dd>

            <dt class="col-sm-4 text-secondary">Matière</dt>
            <dd class="col-sm-8">@Model.Subject?.Nom</dd>

            <dt class="col-sm-4 text-secondary">Classe</dt>
            <dd class="col-sm-8">@Model.ClassRoom?.Nom</dd>

            <dt class="col-sm-4 text-secondary">Date limite</dt>
            <dd class="col-sm-8">@Model.DateLimite.ToString("dd/MM/yyyy")</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash3"></i> Confirmer la suppression
                </button>
                <a asp-action="Index" class="btn btn-light border">Annuler</a>
            </div>
        </form>
    </div>
</div>
